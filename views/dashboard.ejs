<%- include('partials/head') %>
<%- include('partials/sidebar') %>

<main class="flex-1 overflow-y-auto p-4 md:p-8 bg-[#F0F2F5] h-full relative font-sans">
    
    <!-- Top Filter Section -->
    <div class="flex flex-col md:flex-row gap-4 mb-6">
        <input type="text" id="searchInput" placeholder="Cari Judul Live..." class="flex-1 px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#7559AC] shadow-sm text-sm">
        <select id="statusFilter" class="px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#7559AC] shadow-sm text-sm bg-white min-w-[150px] cursor-pointer">
            <option value="Semua">Semua</option>
            <option value="AKTIF">Aktif</option>
            <option value="DIJADWALKAN">Dijadwalkan</option>
        </select>
        <select id="repeatFilter" class="px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#7559AC] shadow-sm text-sm bg-white min-w-[200px] cursor-pointer">
            <option value="Semua">Semua Pengulangan</option>
            <option value="Manual">Manual</option>
            <option value="Harian">Harian</option>
            <option value="Mingguan">Mingguan</option>
        </select>
    </div>

    <!-- Stats Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center">
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">LIVE AKTIF</h3>
            <span class="text-4xl font-extrabold text-[#7559AC]"><%= tasks.filter(t => t.status === 'AKTIF').length %></span>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 text-center">
            <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">TOTAL TUGAS</h3>
            <span class="text-4xl font-extrabold text-[#7559AC]"><%= tasks.length %></span>
        </div>
    </div>

    <!-- Grid Task -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6" id="tasksContainer">
        <% tasks.forEach(task => { %>
            <div class="task-card bg-white rounded-2xl shadow-sm border border-gray-100 border-t-[5px] border-t-[#7559AC] flex flex-col hover:shadow-md transition-shadow" data-title="<%= task.title.toLowerCase() %>" data-status="<%= task.status %>" data-repeat="Mingguan">
                
                <div class="p-5 flex-1 space-y-3">
                    <h3 class="font-bold text-gray-800 text-lg mb-4 uppercase tracking-wide truncate"><%= task.title %></h3>
                    
                    <div class="text-[13px] text-gray-700 space-y-2 leading-relaxed">
                        <p><span class="font-bold text-gray-900">ID:</span> <span class="text-gray-500"><%= task.id %></span></p>
                        <p class="truncate"><span class="font-bold text-gray-900">Video:</span> <%= task.video %></p>
                        <p class="truncate"><span class="font-bold text-gray-900">Key:</span> <%= task.key || (task.youtube_channel_id ? 'API Generated' : 'N/A') %></p>
                        <p class="flex items-center gap-2 mt-1">
                            <span class="font-bold text-gray-900">Status:</span> 
                            <span class="px-2 py-0.5 rounded text-[11px] font-bold tracking-wider <%= task.status === 'AKTIF' ? 'bg-blue-100 text-blue-600' : 'bg-orange-100 text-[#FF8540]' %>">
                                <%= task.status %>
                            </span>
                        </p>
                        
                        <div class="pt-2 space-y-1.5">
                            <% 
                               let startStr = task.start;
                               let endStr = task.end;
                               
                               // Helper function to handle formatting
                               const formatD = (dt) => {
                                  if(!dt) return "-";
                                  const d = new Date(dt);
                                  if (isNaN(d.getTime())) return dt;
                                  return d.toLocaleDateString('id-ID') + ", " + d.toLocaleTimeString('id-ID', { hour: '2-digit', minute:'2-digit' }) + " (WIB)";
                               }
                            %>
                            <p><span class="font-bold text-gray-900">Mulai:</span> <%= formatD(task.start) %></p>
                            <p><span class="font-bold text-gray-900">Berhenti:</span> <%= formatD(task.end) %></p>
                            <p><span class="font-bold text-gray-900">Pengulangan:</span> <%= task.repeat || 'Mingguan' %></p>
                            <p><span class="font-bold text-gray-900">Auto Stop Setelah:</span> <%= task.auto_stop_hour || '12' %> Jam <%= task.auto_stop_min || '0' %> Menit</p>
                        </div>
                    </div>
                </div>

                <div class="px-5 pb-5 mt-2">
                    <form action="/stop-tugas/<%= task.id %>" method="POST">
                        <button type="submit" class="w-full bg-[#7559AC] hover:bg-[#624b91] text-white font-bold py-2.5 rounded-lg transition text-sm tracking-wide">
                            <%= task.status === 'AKTIF' ? 'HENTIKAN' : 'CANCEL' %>
                        </button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
    
    <% if (tasks.length === 0) { %>
        <div class="text-center py-20 bg-white rounded-2xl shadow-sm border border-gray-100 mt-6" id="emptyState">
            <h3 class="text-xl font-bold text-gray-500">Belum ada tugas live.</h3>
            <p class="text-gray-400 mt-2">Klik tombol "+" di sudut kanan bawah untuk membuat tugas baru.</p>
        </div>
    <% } %>

    <!-- Floating Action Button (+) -->
    <a href="/buat-tugas" class="fixed bottom-10 right-10 bg-[#7559AC] hover:bg-[#624b91] text-white rounded-full w-14 h-14 flex items-center justify-center shadow-2xl hover:scale-110 transition-transform z-50">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
    </a>

</main>

<script>
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const repeatFilter = document.getElementById('repeatFilter');
    const taskCards = document.querySelectorAll('.task-card');

    function filterTasks() {
        if (!taskCards.length) return;
        const q = searchInput.value.toLowerCase();
        const s = statusFilter.value;
        const r = repeatFilter.value;

        taskCards.forEach(card => {
            const title = card.getAttribute('data-title');
            const status = card.getAttribute('data-status');
            const repeat = card.getAttribute('data-repeat');

            const matchSearch = title.includes(q);
            const matchStatus = (s === 'Semua') || (status === s);
            const matchRepeat = (r === 'Semua') || (r === 'Semua Pengulangan') || (repeat === r);

            if (matchSearch && matchStatus && matchRepeat) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    if (searchInput) searchInput.addEventListener('input', filterTasks);
    if (statusFilter) statusFilter.addEventListener('change', filterTasks);
    if (repeatFilter) repeatFilter.addEventListener('change', filterTasks);
</script>

</body>
</html>
