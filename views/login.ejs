<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Ezhma Live</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; }
        .font-heading { font-family: 'Montserrat', sans-serif; }
        .bg-custom { background-color: #DEEAF4; } /* Latar belakang biru pucat berdasarkan gambar */
        .text-blue-custom { color: #1C7BC2; }
        .bg-btn-custom { background: linear-gradient(90deg, #5CA9F8 0%, #68C9E9 100%); }
    </style>
</head>
<body class="bg-custom flex items-center justify-center min-h-screen p-4">

    <div class="relative bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.06)] w-full max-w-sm px-8 pt-12 pb-8 mt-12">
        
        <!-- Avatar mengambang Bulat -->
        <div class="absolute -top-16 left-1/2 transform -translate-x-1/2">
            <div class="w-32 h-32 rounded-full border-[5px] border-white overflow-hidden shadow-xl bg-black flex items-center justify-center">
                <img src="/img/logo.svg" alt="Logo" class="w-full h-full object-cover scale-110">
            </div>
        </div>

        <!-- Judul -->
        <div class="text-center mb-6 mt-12">
            <h2 class="font-heading font-bold text-blue-custom text-sm mb-1 leading-tight">Selamat Datang Di Ezhma Live</h2>
            <h3 class="font-heading font-bold text-blue-custom text-sm">by Ezhma Studio</h3>
            <h1 class="font-heading font-extrabold text-[#333333] tracking-tight text-3xl mt-4">Login</h1>
        </div>

        <% if (locals.error && error) { %>
            <div class="bg-red-50 text-red-600 border border-red-200 px-4 py-2 rounded-lg text-sm text-center mb-4">
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-4">
            <!-- Username Input -->
            <div>
                <label class="block text-[#111] text-xs font-bold mb-1.5" for="username">
                    Username:
                </label>
                <input class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg text-gray-800 text-sm focus:outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-400 transition-colors" 
                    id="username" name="username" type="text" value="admin" required>
            </div>
            
            <!-- Password Input -->
            <div>
                <label class="block text-[#111] text-xs font-bold mb-1.5" for="password">
                    Password:
                </label>
                <div class="relative">
                    <input class="w-full px-4 pr-10 py-2.5 bg-[#F9F9F9] border border-gray-200 rounded-lg text-gray-800 text-sm focus:outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-400 transition-colors" 
                        id="password" name="password" type="password" required>
                    <button type="button" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-500 hover:text-gray-700" onclick="togglePassword()">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Remember Me -->
            <div class="flex items-center">
                <input id="remember_me" type="checkbox" class="h-4 w-4 text-blue-500 focus:ring-blue-400 border-gray-300 rounded cursor-pointer">
                <label for="remember_me" class="ml-2 block text-sm text-gray-600 cursor-pointer">
                    Ingat Saya
                </label>
            </div>
            
            <!-- Submit Button -->
            <div class="pt-2">
                <button type="submit" class="w-full bg-btn-custom hover:opacity-90 text-white font-bold py-3 rounded-lg text-lg transition duration-200 shadow-md">
                    Login
                </button>
            </div>

            <!-- Lupa Sandi -->
            <div class="text-center mt-3">
                <a href="#" class="text-sm font-medium text-[color:#003AC0] hover:underline">Lupa Sandi?</a>
            </div>
        </form>
    </div>

    <!-- Script to toggle password visibility -->
    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
            } else {
                passwordInput.type = 'password';
            }
        }
    </script>
</body>
</html>
